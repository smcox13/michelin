OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Optional MCP enrichment
MCP_ENABLED=false
MCP_REQUEST_TIMEOUT_SECONDS=8
MCP_CACHE_TTL_SECONDS=300

# Example finance connector
FINANCE_MCP_ENABLED=true
FINANCE_MCP_TRANSPORT=streamable-http
FINANCE_MCP_URL=https://secedgar.caseyjhand.com/mcp
FINANCE_MCP_COMMAND=
FINANCE_MCP_ARGS=[]
FINANCE_MCP_HEADERS={}
FINANCE_MCP_TOOL=secedgar_get_financials

# Example news connector
NEWS_MCP_ENABLED=true
NEWS_MCP_TRANSPORT=streamable-http
NEWS_MCP_URL=https://mrbridge--latest-news-mcp-server.apify.actor/mcp?token=your_apify_token_here
NEWS_MCP_COMMAND=
NEWS_MCP_ARGS=[]
NEWS_MCP_HEADERS={}
NEWS_MCP_TOOL=get_top_news
